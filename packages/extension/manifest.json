{
  "manifest_version": 3,
  "name": "Grip",
  "description": "Grab anything on the web — element picker, a11y inspector, log reader",
  "version": "0.1.0",
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "permissions": ["activeTab", "debugger", "storage", "scripting"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:9222/*"],
  "background": {
    "service_worker": "src/service_worker/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Grip",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png"
    }
  },
  "devtools_page": "src/devtools/devtools.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content_scripts/inject.ts"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
