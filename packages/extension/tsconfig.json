{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2022", "DOM"],
    "types": ["chrome", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@grip/core": ["../core/src/index.ts"],
      "@grip/devtools": ["../devtools/src/index.ts"],
      "@grip/devtools-lib": ["../devtools/src/lib/index.ts"],
      "@grip/devtools-floating": ["../devtools/src/floating/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../devtools/src/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.js", "src/**/*.d.ts"]
}
