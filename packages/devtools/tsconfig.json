{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2022", "DOM"],
    "types": ["chrome", "vite/client", "node"],
    "noEmit": true,
    "paths": {
      "@devtools/*": ["./src/*"],
      "grip-dev": ["../../packages/core/src/index.ts"],
      "@lib": ["./src/lib/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
