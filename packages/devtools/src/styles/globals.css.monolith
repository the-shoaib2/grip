  color: var(--grip-muted);
}

.grip-pick-item:hover {
  background: transparent;
}

.grip-pick-row-active .grip-pick-item {
  color: var(--grip-accent-fg);
}

.grip-pick-row-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 0.125rem;
  opacity: 0;
  pointer-events: none;
