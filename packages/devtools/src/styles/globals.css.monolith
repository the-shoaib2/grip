}

.grip-pick-row-active {
  background: var(--grip-accent-soft);
}

.grip-pick-row-active:hover {
  background: var(--grip-accent-soft);
}

.grip-pick-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.125rem;
  min-width: 0;
  flex: 1;
  overflow: hidden;
  border: 0;
  background: transparent;
  padding: 0.125rem 0;
  text-align: left;
  font-size: 12px;
  line-height: 1.25;
  color: var(--grip-fg);
