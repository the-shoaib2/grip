  flex-shrink: 0;
  border: none;
  background: transparent;
  color: var(--grip-muted);
}

.grip-pick-row .grip-btn-icon:hover {
  background: var(--grip-surface-hover);
  color: var(--grip-fg);
}

.grip-pick-row-active .grip-btn-icon {
  background: transparent;
  color: var(--grip-accent-fg);
}

.grip-pick-row-active .grip-btn-icon:hover {
