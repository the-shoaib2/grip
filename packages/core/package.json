{
  "name": "grip-dev",
  "version": "0.1.0",
  "description": "Grip core — selectors, accessibility snapshots, ref maps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-shoaib2/grip.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/the-shoaib2/grip/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/the-shoaib2/grip/issues"
  },
  "keywords": [
    "grip",
    "mcp",
    "model-context-protocol",
    "accessibility",
    "selector",
    "browser-automation",
    "chrome-devtools-protocol"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "require": "./dist/mcp/index.cjs"
    },
    "./types": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "imports": {
    "#types/*": "./src/types/*"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.dts.json",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@medv/finder": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.6",
    "jsdom": "^24.1.0"
  }
}
