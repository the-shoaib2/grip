{
  "name": "grip",
  "private": true,
  "description": "Grab anything on the web.",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=@grip/playground --filter=@grip/extension",
    "dev:playground": "turbo dev --filter=@grip/playground --filter=@grip/devtools",
    "dev:extension": "pnpm --filter @grip/extension dev",
    "dev:grip": "pnpm --filter @grip/cli start dev",
    "grip": "pnpm --filter @grip/cli start",
    "dev:ui": "turbo dev --filter=@grip/playground --filter=@grip/devtools",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "build:mcp": "bash scripts/build-mcp.sh",
    "publish:core": "pnpm --filter grip-dev build && pnpm --filter grip-dev test && npm publish ./packages/core --access public",
    "publish:core:dry-run": "npm publish ./packages/core --access public --dry-run",
    "release": "changeset publish",
    "smoke": "pnpm --filter grip-dev test",
    "test:e2e": "playwright test -c e2e/playwright.config.mjs",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.mjs --ui"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.45.0",
    "eslint": "^9.0.0",
    "globals": "^17.7.0",
    "playwright": "^1.45.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.15.0"
  },
  "packageManager": "pnpm@10.3.0",
  "engines": {
    "node": ">=20"
  }
}
