{
  "name": "grip-mcp",
  "version": "0.1.0",
  "description": "Grip — browser automation MCP server via Chrome DevTools Protocol",
  "type": "module",
  "bin": {
    "grip-mcp": "./dist/cli.js"
  },
  "scripts": {
