# --- Build outputs ---

# Shared package dist (tsup)
packages/*/dist/

# Next.js docs
apps/docs/.next/
apps/docs/out/
apps/playground/dist/

# Chrome extension (Vite + CRXJS)
packages/extension/dist/
# Accidental tsc output in extension source (use vite build, not tsc emit)
packages/extension/src/**/*.js
packages/extension/src/**/*.d.ts
packages/extension/src/**/*.js.map
packages/extension/src/**/*.d.ts.map
# Accidental tsc output in core source
packages/core/src/**/*.js
packages/core/src/**/*.d.ts
packages/core/src/**/*.js.map
packages/core/src/**/*.d.ts.map

# Go MCP server
bin/grip-mcp
packages/mcp-server/grip-mcp
packages/mcp-server/bin/

