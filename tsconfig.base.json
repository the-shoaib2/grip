{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "paths": {
      "@grip/core": ["./packages/core/src/index.ts"],
      "@grip/devtools": ["./packages/devtools/src/index.ts"],
      "@grip/devtools/lib": ["./packages/devtools/src/lib/index.ts"],
      "@grip/devtools-lib": ["./packages/devtools/src/lib/index.ts"],
      "@grip/devtools-floating": ["./packages/devtools/src/floating/index.ts"],
      "@grip/devtools-css": ["./packages/devtools/src/styles/globals.css"]
    }
  }
}
